// ==================== THINGSPEAK CONFIG ====================
class ThingSpeakConfig {
  static const String channelId  = '3339084';
  static const String readApiKey = 'ADDGSHMU6DBRW70I';
}

// ==================== THINGSPEAK SERVICE ====================
class ThingSpeakService {
  static const String _base = 'https://api.thingspeak.com';

  static Future<Map<String, dynamic>?> getLastFeed() async {
    try {
      final url = '$_base/channels/${ThingSpeakConfig.channelId}'
          '/feeds/last.json?api_key=${ThingSpeakConfig.readApiKey}';
      final r = await http.get(Uri.parse(url)).timeout(const Duration(seconds: 6));
      if (r.statusCode == 200) return jsonDecode(r.body);
    } catch (_) {}
    return null;
  }

  static Future<List<Map<String, dynamic>>> getFeeds({int results = 20}) async {
    try {
      final url = '$_base/channels/${ThingSpeakConfig.channelId}'
          '/feeds.json?api_key=${ThingSpeakConfig.readApiKey}&results=$results';
      final r = await http.get(Uri.parse(url)).timeout(const Duration(seconds: 8));
      if (r.statusCode == 200) {
        final data = jsonDecode(r.body);
        return List<Map<String, dynamic>>.from(data['feeds'] ?? []);
      }
    } catch (_) {}
    return [];
  }

  static Map<String, dynamic> parseFeed(Map<String, dynamic> feed) {
    return {
      'temp':     double.tryParse(feed['field1'] ?? '') ?? 0.0,
      'humidity': double.tryParse(feed['field2'] ?? '') ?? 0.0,
      'soil':     int.tryParse(feed['field3'] ?? '') ?? 0,
      'pump':     (feed['field4'] ?? '0') == '1',
      'time':     feed['created_at'] ?? '',
    };
  }
}

