  late AnimationController _c;
  late Animation<double> _scale;
  @override
  void initState() {
    super.initState();
    _c = AnimationController(vsync: this, duration: const Duration(milliseconds: 1200));
    _scale = Tween<double>(begin: 1.0, end: 1.3).animate(CurvedAnimation(parent: _c, curve: Curves.easeInOut));
    if (widget.active) _c.repeat(reverse: true);
  }
  @override
  void didUpdateWidget(_AnimatedTempIcon old) {
    super.didUpdateWidget(old);
    widget.active ? _c.repeat(reverse: true) : (_c..stop()..value = 0);
  }
  @override
  void dispose() { _c.dispose(); super.dispose(); }
  @override
  Widget build(BuildContext context) {
    return ScaleTransition(
      scale: _scale,
      child: Icon(Icons.thermostat_rounded, color: widget.active ? Colors.orange : Colors.grey, size: 20),
    );
  }
}

