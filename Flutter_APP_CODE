// ==================== MAIN SCREEN ====================
class MainScreen extends StatefulWidget {
  final String? ip;
  final String deviceName;
  final BluetoothDevice? bleDevice;
  const MainScreen({super.key, this.ip, required this.deviceName, this.bleDevice});
  @override
  State<MainScreen> createState() => _MainScreenState();
}

class _MainScreenState extends State<MainScreen> {
  int _index = 0;
  bool pumpStatus    = false;
  bool pumpConnected = true;
  int soilMoisture   = 0;
  bool soilConnected = false;
  double temp        = 0;
  double humidity    = 0;
  bool dhtConnected  = false;
  bool connected     = false;
  int waterCount     = 0;
  double totalWaterTime = 0;
  Timer? timer;
  List<Map<String, dynamic>> logs = [];
  String secretKey  = '';
  bool _keyEntered  = false;
  bool isBLE        = false;

  BluetoothCharacteristic? _bleChar;
  StreamSubscription? _bleNotifySub;
  StreamSubscription? _bleStatesSub;
  Completer<String>? _pendingResponse;

  List<Map<String, dynamic>> _tsHistory = [];
  bool _tsLoading = false;

  @override
  void initState() {
    super.initState();
    isBLE = widget.bleDevice != null;
    if (isBLE) {
      _connectBLE();
    } else {
      WidgetsBinding.instance.addPostFrameCallback((_) => _loadSavedData());
    }
  }

  Future<void> _loadSavedData() async {
    final prefs = await SharedPreferences.getInstance();
    final saved = prefs.getString('secret_key_${widget.ip}') ?? '';
    if (saved.isNotEmpty) {
      secretKey   = saved;
      _keyEntered = true;
      _startPolling();
    } else {
      _showKeyDialog();
    }
  }

  Future<void> _saveKey(String key) async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString('secret_key_${widget.ip}', key);
  }

  Future<void> _clearKey() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.remove('secret_key_${widget.ip}');
  }

  void _startPolling() {
    timer?.cancel();
    timer = Timer.periodic(const Duration(seconds: 3), (_) => getStatus());
    getStatus();
  }

  void _showKeyDialog() {
    String key = '';
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (_) => AlertDialog(
        backgroundColor: const Color(0xFF222222),
        title: const Text('كلمة السر', style: TextStyle(color: Colors.white)),
        content: TextField(
          style: const TextStyle(color: Colors.white),
          obscureText: true,
          decoration: const InputDecoration(
            hintText: 'أدخل كلمة السر (اتركه فارغاً إن لم يكن)',
            hintStyle: TextStyle(color: Colors.grey),
            border: OutlineInputBorder(),
          ),
          onChanged: (v) => key = v,
        ),
        actions: [
          ElevatedButton(
            style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFF2E7D32)),
            onPressed: () {
              secretKey   = key;
              _keyEntered = true;
              Navigator.pop(context);
              _saveKey(key);
              _startPolling();
            },
            child: const Text('دخول', style: TextStyle(color: Colors.white)),
          ),
        ],
      ),
    );
  }

  // ==================== BLE ====================
  Future<void> _connectBLE() async {
    if (widget.bleDevice == null) return;
    final device = widget.bleDevice!;

    _bleStatesSub = device.connectionState.listen((state) async {
      if (state == BluetoothConnectionState.disconnected && mounted) {
        setState(() => connected = false);
        await Future.delayed(const Duration(seconds: 3));
        if (mounted) _connectBLE();
      }
    });

    try {
      await device.connect(timeout: const Duration(seconds: 10), autoConnect: false);
    } catch (e) {
      if (!mounted) return;
      if (!e.toString().contains('already')) {
        setState(() => connected = false);
        _showSnack('❌ فشل الاتصال بـ Bluetooth', Colors.red);
        return;
      }
    }

    try {
      final services = await device.discoverServices();
      BluetoothCharacteristic? found;

      for (var s in services) {
        if (!s.serviceUuid.toString().toLowerCase().contains('12345678')) continue;
        for (var c in s.characteristics) {
          if (c.characteristicUuid.toString().toLowerCase().contains('abcdefab')) {
            found = c;
            break;
          }
        }
        if (found != null) break;
      }

      if (found == null) {
        if (!mounted) return;
        setState(() => connected = false);
        _showSnack('❌ Characteristic غير موجود', Colors.red);
        return;
      }

      _bleChar = found;
      await _bleChar!.setNotifyValue(true);

      _bleNotifySub = _bleChar!.onValueReceived.listen((data) {
        if (data.isEmpty) return;
        final str = utf8.decode(data);
        if (_pendingResponse != null && !_pendingResponse!.isCompleted) {
          _pendingResponse!.complete(str);
        }
      });

      if (!mounted) return;
      setState(() => connected = true);
      timer?.cancel();
      timer = Timer.periodic(const Duration(seconds: 3), (_) => getStatus());
      getStatus();
    } catch (e) {
      if (!mounted) return;
      setState(() => connected = false);
      _showSnack('❌ خطأ: $e', Colors.red);
    }
  }

  Future<String?> _bleSendAndWait(String cmd, {Duration timeout = const Duration(seconds: 5)}) async {
    if (_bleChar == null || !connected) return null;
    try {
      _pendingResponse = Completer<String>();
      final payload = jsonEncode({'cmd': cmd, 'key': secretKey});
      await _bleChar!.write(utf8.encode(payload), withoutResponse: false);
      final response = await _pendingResponse!.future.timeout(timeout);
      _pendingResponse = null;
      return response;
    } on TimeoutException {
      _pendingResponse = null;
      return null;
    } catch (_) {
      _pendingResponse = null;
      return null;
    }
  }

  Map<String, String> _getHeaders() =>
      {'X-Secret-Key': secretKey, 'Content-Type': 'application/json'};

  Future<void> getStatus() async {
    if (!isBLE) {
      if (!_keyEntered) return;
      try {
        final r = await http.get(Uri.parse('http://${widget.ip}/status'), headers: _getHeaders())
            .timeout(const Duration(seconds: 3));
        if (!mounted) return;
        if (r.statusCode == 200) {
          _parseStatusJson(jsonDecode(r.body));
        } else if (r.statusCode == 401) {
          await _clearKey();
          _showSnack('كلمة السر غلط', Colors.red);
          _showKeyDialog();
        }
      } catch (_) {
        if (!mounted) return;
        setState(() => connected = false);
        NotificationService.checkAndNotify(connected: false, soilConnected: false, soilMoisture: 0, dhtConnected: false, temp: 0);
      }
      return;
    }

    if (_bleChar == null) return;
    final response = await _bleSendAndWait('status');
    if (!mounted) return;
    if (response == null) {
      setState(() => connected = false);
      NotificationService.checkAndNotify(connected: false, soilConnected: false, soilMoisture: 0, dhtConnected: false, temp: 0);
      return;
    }
    try {
      final d = jsonDecode(response) as Map<String, dynamic>;
      if (d['error'] == 'unauthorized') {
        _showSnack('كلمة السر غلط', Colors.red);
        _showKeyDialog();
        return;
      }
      _parseStatusJson(d);
    } catch (_) {}
  }

  void _parseStatusJson(Map<String, dynamic> d) {
    if (!mounted) return;
    setState(() {
      pumpStatus     = d['pump'] == 1;
      pumpConnected  = d['pumpConnected'] ?? true;
      soilMoisture   = d['soil'] ?? 0;
      soilConnected  = d['soilConnected'] ?? false;
      temp           = (d['temp'] ?? 0).toDouble();
      humidity       = (d['humidity'] ?? 0).toDouble();
      dhtConnected   = d['dhtConnected'] ?? false;
      waterCount     = d['waterCount'] ?? 0;
      totalWaterTime = (d['totalWaterTime'] ?? 0).toDouble();
      connected      = true;
    });
    NotificationService.checkAndNotify(
      connected: true, soilConnected: soilConnected,
      soilMoisture: soilMoisture, dhtConnected: dhtConnected, temp: temp,
    );
  }

  Future<void> pumpOn() async {
    if (!connected) { _showSnack('⚠️ الجهاز غير متصل', Colors.orange); return; }
    try {
      if (isBLE) {
        final r = await _bleSendAndWait('pump_on');
        if (!mounted) return;
        if (r != null) setState(() => pumpStatus = true);
      } else {
        final r = await http.get(Uri.parse('http://${widget.ip}/pump/on'), headers: _getHeaders());
        if (!mounted) return;
        if (r.statusCode == 200) { setState(() => pumpStatus = true); }
        else if (r.statusCode == 401) { await _clearKey(); _showSnack('كلمة السر غلط', Colors.red); _showKeyDialog(); return; }
      }
      addLog('تشغيل المضخة يدوياً');
      _showSnack('✅ تم تشغيل المضخة', const Color(0xFF4CAF50));
    } catch (_) { _showSnack('❌ فشل الاتصال', Colors.red); }
  }

  Future<void> pumpOff() async {
    if (!connected) { _showSnack('⚠️ الجهاز غير متصل', Colors.orange); return; }
    try {
      if (isBLE) {
        final r = await _bleSendAndWait('pump_off');
        if (!mounted) return;
        if (r != null) setState(() => pumpStatus = false);
      } else {
        final r = await http.get(Uri.parse('http://${widget.ip}/pump/off'), headers: _getHeaders());
        if (!mounted) return;
        if (r.statusCode == 200) { setState(() => pumpStatus = false); }
        else if (r.statusCode == 401) { await _clearKey(); _showSnack('كلمة السر غلط', Colors.red); _showKeyDialog(); return; }
      }
      addLog('إيقاف المضخة يدوياً');
      _showSnack('⛔ تم إيقاف المضخة', Colors.orange);
    } catch (_) { _showSnack('❌ فشل الاتصال', Colors.red); }
  }

  Future<void> autoWater() async {
    if (!connected) { _showSnack('⚠️ الجهاز غير متصل', Colors.orange); return; }
    try {
      String status = 'notneed';
      if (isBLE) {
        final r = await _bleSendAndWait('auto', timeout: const Duration(seconds: 10));
        if (!mounted) return;
        if (r != null) status = (jsonDecode(r))['status'] ?? 'notneed';
      } else {
        final r = await http.get(Uri.parse('http://${widget.ip}/auto'), headers: _getHeaders());
        if (!mounted) return;
        status = jsonDecode(r.body)['status'] ?? 'notneed';
      }
      final msg = status == 'watered' ? '💧 تم الري التلقائي' : '✅ التربة رطبة';
      addLog(msg);
      _showSnack(msg, const Color(0xFF4CAF50));
      getStatus();
    } catch (_) { _showSnack('❌ فشل الاتصال', Colors.red); }
  }

  Future<void> loadThingSpeakHistory() async {
    setState(() => _tsLoading = true);
    try {
      final feeds = await ThingSpeakService.getFeeds(results: 20);
      if (!mounted) return;
      setState(() {
        _tsHistory = feeds.map(ThingSpeakService.parseFeed).toList();
        _tsLoading = false;
      });
    } catch (e) {
      if (!mounted) return;
      setState(() => _tsLoading = false);
      _showSnack('❌ خطأ ThingSpeak: $e', Colors.red);
    }
  }

  void addLog(String msg) {
    if (!mounted) return;
    setState(() {
      final now = DateTime.now();
      logs.insert(0, {
        'message': msg,
        'time': '${now.hour.toString().padLeft(2, '0')}:${now.minute.toString().padLeft(2, '0')}',
        'date': '${now.day}/${now.month}/${now.year}',
      });
      if (logs.length > 100) logs.removeLast();
    });
  }

  void _showSnack(String msg, Color color) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(msg), backgroundColor: color,
      behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(10)),
    ));
  }

  @override
  void dispose() {
    timer?.cancel();
    _bleNotifySub?.cancel();
    _bleStatesSub?.cancel();
    _pendingResponse = null;
    widget.bleDevice?.disconnect();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final pages = [
      _DashboardPage(
        deviceName: widget.deviceName, ip: widget.ip ?? 'BLE',
        pumpStatus: pumpStatus, pumpConnected: pumpConnected,
        soilMoisture: soilMoisture, soilConnected: soilConnected,
        temp: temp, humidity: humidity, dhtConnected: dhtConnected,
        connected: connected, waterCount: waterCount,
        totalWaterTime: totalWaterTime, isBLE: isBLE,
        onPumpOn: pumpOn, onPumpOff: pumpOff, onAutoWater: autoWater,
      ),
      _ThingSpeakPage(
        channelId: ThingSpeakConfig.channelId,
        history: _tsHistory,
        loading: _tsLoading,
        onRefresh: loadThingSpeakHistory,
      ),
      _LogsPage(logs: logs),
      _SettingsPage(
        ip: widget.ip ?? 'BLE',
        deviceName: widget.deviceName,
        onChangeKey: () async {
          await _clearKey();
          NotificationService.resetAll();
          if (!mounted) return;
          Navigator.pushReplacement(context,
              MaterialPageRoute(builder: (_) => MainScreen(ip: widget.ip, deviceName: widget.deviceName)));
        },
      ),
    ];

    return Scaffold(
      backgroundColor: const Color(0xFFF5F5F5),
      body: pages[_index],
      bottomNavigationBar: Container(
        decoration: const BoxDecoration(
          color: Colors.white,
          border: Border(top: BorderSide(color: Color(0xFFE8E8E8), width: 0.5)),
        ),
        child: BottomNavigationBar(
          currentIndex: _index,
          onTap: (i) {
            setState(() => _index = i);
            if (i == 1) loadThingSpeakHistory();
          },
          backgroundColor: Colors.transparent,
          selectedItemColor: const Color(0xFF2E7D32),
          unselectedItemColor: Colors.grey,
          type: BottomNavigationBarType.fixed,
          elevation: 0,
          items: const [
            BottomNavigationBarItem(icon: Icon(Icons.dashboard_rounded), label: 'الرئيسية'),
            BottomNavigationBarItem(icon: Icon(Icons.cloud_rounded),     label: 'ThingSpeak'),
            BottomNavigationBarItem(icon: Icon(Icons.history_rounded),   label: 'السجل'),
            BottomNavigationBarItem(icon: Icon(Icons.settings_rounded),  label: 'الإعدادات'),
          ],
        ),
      ),
    );
  }
}

