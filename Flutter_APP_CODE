// ==================== CONNECT SCREEN ====================
class ConnectScreen extends StatefulWidget {
  const ConnectScreen({super.key});
  @override
  State<ConnectScreen> createState() => _ConnectScreenState();
}

class _ConnectScreenState extends State<ConnectScreen> with TickerProviderStateMixin {
  late AnimationController _ctrl;
  int _tab = 0;
  bool scanning = false;
  List<Map<String, dynamic>> wifiDevices = [];
  List<BluetoothDevice> bleDevices = [];
  String status = 'اضغط للبحث';
  final TextEditingController _ipCtrl = TextEditingController();
  String manualIP = '';
  StreamSubscription? _bleScan;

  @override
  void initState() {
    super.initState();
    _ctrl = AnimationController(vsync: this, duration: const Duration(seconds: 2))..repeat();
    _requestPermissions();
  }

  @override
  void dispose() { _ctrl.dispose(); _bleScan?.cancel(); super.dispose(); }

  Future<void> _requestPermissions() async {
    await [
      Permission.bluetooth,
      Permission.bluetoothScan,
      Permission.bluetoothConnect,
      Permission.location,
    ].request();
  }

  Future<void> scanWiFi() async {
    setState(() { scanning = true; wifiDevices.clear(); status = 'جاري البحث...'; });

    // محاولة mDNS أولاً
    final mdnsHosts = ['smartdrop.local', 'smartdrop-1.local', 'smartdrop-2.local'];
    for (final host in mdnsHosts) {
      try {
        final r = await http.get(Uri.parse('http://$host/discover'))
            .timeout(const Duration(seconds: 2));
        if (r.statusCode == 200) {
          final d = jsonDecode(r.body);
          if (d['type'] == 'SmartDrop' && mounted) {
            setState(() => wifiDevices.add({'ip': host, 'name': d['device']}));
          }
        }
      } catch (_) {}
    }

    if (wifiDevices.isNotEmpty) {
      if (mounted) setState(() { scanning = false; status = 'تم العثور على ${wifiDevices.length} جهاز'; });
      return;
    }

    // مسح الشبكة بـ batches أكبر وأسرع
    if (mounted) setState(() => status = 'جاري مسح الشبكة...');
    final ranges = ['192.168.1', '192.168.0', '192.168.4', '10.0.0', '10.68.0', '172.16.0'];

    for (final range in ranges) {
      if (wifiDevices.isNotEmpty) break;
      final futures = <Future>[];
      for (int i = 1; i <= 254; i++) {
        final ip = '$range.$i';
        futures.add(
          http.get(Uri.parse('http://$ip/discover'))
              .timeout(const Duration(milliseconds: 200))  // ← 200ms أسرع
              .then((r) {
                if (r.statusCode == 200) {
                  final d = jsonDecode(r.body);
                  if (d['type'] == 'SmartDrop' && mounted) {
                    setState(() => wifiDevices.add({'ip': ip, 'name': d['device']}));
                  }
                }
              }).catchError((_) {}),
        );
        if (futures.length >= 50) {  // ← 50 بدل 20 — أسرع
          await Future.wait(futures);
          futures.clear();
        }
      }
      if (futures.isNotEmpty) await Future.wait(futures);
    }

    if (mounted) setState(() {
      scanning = false;
      status = wifiDevices.isEmpty ? 'لم يتم العثور على أجهزة' : 'تم العثور على ${wifiDevices.length} جهاز';
    });
  }

  Future<void> scanBLE() async {
    setState(() { scanning = true; bleDevices.clear(); status = 'جاري البحث عن أجهزة BLE...'; });

    final adapterState = await FlutterBluePlus.adapterState.first;
    if (adapterState != BluetoothAdapterState.on) {
      if (mounted) setState(() { scanning = false; status = 'يرجى تفعيل البلوتوث أولاً'; });
      return;
    }

    _bleScan?.cancel();
    await FlutterBluePlus.stopScan();

    _bleScan = FlutterBluePlus.onScanResults.listen((results) {
      for (var r in results) {
        final name = r.device.platformName;
        if (name.isNotEmpty &&
            name.contains('SmartDrop') &&
            !bleDevices.any((d) => d.remoteId == r.device.remoteId) &&
            mounted) {
          setState(() => bleDevices.add(r.device));
        }
      }
    });

    await FlutterBluePlus.startScan(
      timeout: const Duration(seconds: 10),
      androidUsesFineLocation: true,
    );

    if (mounted) setState(() {
      scanning = false;
      status = bleDevices.isEmpty ? 'لم يتم العثور على أجهزة BLE' : 'تم العثور على ${bleDevices.length} جهاز';
    });
  }

  Future<void> connectWiFiManual() async {
    if (manualIP.isEmpty) return;
    try {
      final r = await http.get(Uri.parse('http://$manualIP/discover'))
          .timeout(const Duration(seconds: 5));
      if (r.statusCode == 200) {
        final d = jsonDecode(r.body);
        if (d['type'] == 'SmartDrop') {
          _goToMain(ip: manualIP, name: d['device']);
        } else {
          _showError('الجهاز ليس SmartDrop');
        }
      }
    } catch (_) {
      _showError('لا يمكن الاتصال بالجهاز');
    }
  }

  void _showError(String msg) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(msg), backgroundColor: Colors.red,
      behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(10)),
    ));
  }

  void _goToMain({String? ip, String? name, BluetoothDevice? bleDevice}) {
    Navigator.pushReplacement(context, _fadeRoute(MainScreen(
      ip: ip, deviceName: name ?? 'SmartDrop', bleDevice: bleDevice,
    )));
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFF111111),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(20),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              const SizedBox(height: 20),
              Row(children: [
                Container(
                  width: 40, height: 40,
                  decoration: const BoxDecoration(shape: BoxShape.circle, color: Color(0xFF2E7D32)),
                  child: const Icon(Icons.water_drop_rounded, size: 20, color: Colors.white),
                ),
                const SizedBox(width: 10),
                const Text('SmartDrop', style: TextStyle(fontSize: 22, fontWeight: FontWeight.bold, color: Colors.white)),
              ]),
              const SizedBox(height: 30),
              const Text('اتصل بجهازك', style: TextStyle(fontSize: 28, fontWeight: FontWeight.bold, color: Colors.white)),
              const SizedBox(height: 20),
              Container(
                padding: const EdgeInsets.all(4),
                decoration: BoxDecoration(color: const Color(0xFF222222), borderRadius: BorderRadius.circular(15)),
                child: Row(children: [
                  _buildTab(0, Icons.wifi, 'WiFi'),
                  _buildTab(1, Icons.bluetooth, 'Bluetooth'),
                ]),
              ),
              const SizedBox(height: 20),
              if (_tab == 0) ...[
                Container(
                  padding: const EdgeInsets.symmetric(horizontal: 15, vertical: 5),
                  decoration: BoxDecoration(
                    color: const Color(0xFF222222),
                    borderRadius: BorderRadius.circular(15),
                    border: Border.all(color: const Color(0xFF4CAF50).withValues(alpha: 0.3)),
                  ),
                  child: Row(children: [
                    const Icon(Icons.wifi, color: Color(0xFF4CAF50), size: 20),
                    const SizedBox(width: 10),
                    Expanded(child: TextField(
                      controller: _ipCtrl,
                      style: const TextStyle(color: Colors.white),
                      decoration: const InputDecoration(
                        hintText: 'أدخل IP يدوياً أو smartdrop.local',
                        hintStyle: TextStyle(color: Colors.grey),
                        border: InputBorder.none,
                      ),
                      onChanged: (v) => manualIP = v,
                    )),
                    GestureDetector(
                      onTap: connectWiFiManual,
                      child: Container(
                        padding: const EdgeInsets.symmetric(horizontal: 15, vertical: 8),
                        decoration: BoxDecoration(color: const Color(0xFF2E7D32), borderRadius: BorderRadius.circular(10)),
                        child: const Text('اتصال', style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
                      ),
                    ),
                  ]),
                ),
                const SizedBox(height: 20),
              ],
              Center(
                child: GestureDetector(
                  onTap: scanning ? null : (_tab == 0 ? scanWiFi : scanBLE),
                  child: AnimatedBuilder(
                    animation: _ctrl,
                    builder: (_, __) => Stack(
                      alignment: Alignment.center,
                      children: [
                        if (scanning) ...[
                          Container(
                            width: 160 + _ctrl.value * 50, height: 160 + _ctrl.value * 50,
                            decoration: BoxDecoration(
                              shape: BoxShape.circle,
                              border: Border.all(color: const Color(0xFF4CAF50).withValues(alpha: 1 - _ctrl.value), width: 2),
                            ),
                          ),
                          Container(
                            width: 130 + _ctrl.value * 50, height: 130 + _ctrl.value * 50,
                            decoration: BoxDecoration(
                              shape: BoxShape.circle,
                              border: Border.all(color: const Color(0xFF4CAF50).withValues(alpha: 0.5 - _ctrl.value * 0.5), width: 1),
                            ),
                          ),
                        ],
                        Container(
                          width: 100, height: 100,
                          decoration: BoxDecoration(
                            shape: BoxShape.circle,
                            color: const Color(0xFF2E7D32),
                            boxShadow: [BoxShadow(color: const Color(0xFF4CAF50).withValues(alpha: 0.4), blurRadius: 20)],
                          ),
                          child: Icon(
                            scanning ? Icons.wifi_find : (_tab == 0 ? Icons.wifi : Icons.bluetooth),
                            size: 40, color: Colors.white,
                          ),
                        ),
                      ],
                    ),
                  ),
                ),
              ),
              const SizedBox(height: 15),
              Center(child: Text(status, style: const TextStyle(color: Colors.grey, fontSize: 14))),
              const SizedBox(height: 20),
              if (_tab == 0)
                ...wifiDevices.map((d) => GestureDetector(
                  onTap: () => _goToMain(ip: d['ip'], name: d['name']),
                  child: _DeviceCard(name: d['name'], subtitle: d['ip'], icon: Icons.wifi),
                )),
              if (_tab == 1)
                ...bleDevices.map((d) => GestureDetector(
                  onTap: () => _goToMain(bleDevice: d, name: d.platformName),
                  child: _DeviceCard(name: d.platformName, subtitle: d.remoteId.toString(), icon: Icons.bluetooth),
                )),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildTab(int index, IconData icon, String label) {
    final active = _tab == index;
    return Expanded(
      child: GestureDetector(
        onTap: () => setState(() => _tab = index),
        child: Container(
          padding: const EdgeInsets.symmetric(vertical: 12),
          decoration: BoxDecoration(
            color: active ? const Color(0xFF2E7D32) : Colors.transparent,
            borderRadius: BorderRadius.circular(12),
          ),
          child: Row(mainAxisAlignment: MainAxisAlignment.center, children: [
            Icon(icon, color: active ? Colors.white : Colors.grey, size: 18),
            const SizedBox(width: 8),
            Text(label, style: TextStyle(color: active ? Colors.white : Colors.grey, fontWeight: FontWeight.bold)),
          ]),
        ),
      ),
    );
  }
}

