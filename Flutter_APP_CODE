// ==================== NOTIFICATIONS ====================
class NotificationService {
  static final _plugin = FlutterLocalNotificationsPlugin();
  static bool _initialized    = false;
  static bool _soilAlertSent  = false;
  static bool _disconnectSent = false;
  static bool _dhtAlertSent   = false;

  static Future<void> init() async {
    if (_initialized) return;
    const android = AndroidInitializationSettings('@mipmap/ic_launcher');
    const ios = DarwinInitializationSettings(
      requestAlertPermission: true,
      requestBadgePermission: true,
      requestSoundPermission: true,
    );
    await _plugin.initialize(const InitializationSettings(android: android, iOS: ios));
    await _plugin
        .resolvePlatformSpecificImplementation<AndroidFlutterLocalNotificationsPlugin>()
        ?.requestNotificationsPermission();
    _initialized = true;
  }

  static Future<void> _send(int id, String title, String body) async {
    await _plugin.show(id, title, body,
      const NotificationDetails(
        android: AndroidNotificationDetails(
          'smartdrop_channel', 'SmartDrop تنبيهات',
          channelDescription: 'تنبيهات نظام الري الذكي',
          importance: Importance.high,
          priority: Priority.high,
          icon: '@mipmap/ic_launcher',
        ),
        iOS: DarwinNotificationDetails(presentAlert: true, presentSound: true),
      ),
    );
  }

  static Future<void> checkAndNotify({
    required bool connected,
    required bool soilConnected,
    required int soilMoisture,
    required bool dhtConnected,
    required double temp,
  }) async {
    if (!connected) {
      if (!_disconnectSent) {
        _disconnectSent = true;
        await _send(1, '⚠️ SmartDrop غير متصل', 'تم فقدان الاتصال بالجهاز');
      }
      return;
    }
    _disconnectSent = false;

    if (soilConnected && soilMoisture < 30) {
      if (!_soilAlertSent) {
        _soilAlertSent = true;
        await _send(2, '💧 التربة جافة!', 'رطوبة التربة $soilMoisture% — يحتاج ري الآن');
      }
    } else {
      _soilAlertSent = false;
    }

    if (dhtConnected && temp > 40) {
      if (!_dhtAlertSent) {
        _dhtAlertSent = true;
        await _send(3, '🌡️ حرارة عالية!', 'درجة الحرارة ${temp.toStringAsFixed(1)}°C — تحقق من النبات');
      }
    } else {
      _dhtAlertSent = false;
    }
  }

  static void resetAll() {
    _soilAlertSent = _disconnectSent = _dhtAlertSent = false;
  }
}

